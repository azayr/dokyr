HTTP_PORT=8888
HTTPS_PORT=8443
PUBLIC_URL=http://localhost:8888
# Direct IPv4 access is always allowed. Add space-separated control-panel domains here.
CONTROL_HOSTS=localhost
POSTGRES_PASSWORD=change-this-database-password
JWT_SECRET=change-this-jwt-secret-with-at-least-32-characters
ENCRYPTION_KEY=change-this-encryption-key-with-at-least-32-characters
COOKIE_SECURE=false

# Optional GitLab OAuth configuration. GitHub is connected through a private
# GitHub App created from Settings → Security and needs no environment keys.
# For GitLab repository OAuth, use this callback URL:
# http://localhost:8888/api/integrations/oauth/gitlab/callback
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com

# Optional one-time SMTP bootstrap. When SMTP_HOST or SMTP_FROM_EMAIL is set
# and PostgreSQL has no SMTP settings row yet, these values are encrypted and
# copied into the database. After that first import, the database is the only
# source of truth and Compose restarts never overwrite changes made in the UI.
SMTP_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
# starttls, tls, or none
SMTP_ENCRYPTION=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Dokyr
SMTP_FROM_EMAIL=
SMTP_NOTIFY_DEPLOYMENT_FAILURES=true
SMTP_NOTIFY_DEPLOYMENT_SUCCESSES=false
